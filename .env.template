# Angels AI School - Environment Variables
# Copy this to .env and fill in your actual values

# === Database ===
DATABASE_URL=postgresql://user:password@host:5432/angels_ai_school
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key

# === Twilio (WhatsApp & SMS) ===
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP_NUMBER=+14155238886
TWILIO_SMS_NUMBER=+1234567890

# === Africa's Talking (USSD & SMS) ===
AFRICAS_TALKING_USERNAME=your_username
AFRICAS_TALKING_API_KEY=your_api_key
AFRICAS_TALKING_USSD_CODE=*123*45#

# === Google Cloud (OCR) ===
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json

# === Mobile Money ===
MTN_API_KEY=your_mtn_key
AIRTEL_API_KEY=your_airtel_key

# === App Configuration ===
SECRET_KEY=your-super-secret-jwt-key-change-this
FRONTEND_URL=https://your-school.vercel.app
BACKEND_URL=https://your-api.onrender.com

# === Optional ===
ENVIRONMENT=production
PORT=8000
